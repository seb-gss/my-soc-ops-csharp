<div class="fixed inset-0 flex items-center justify-center p-4 z-50"
     style="background:rgba(5,0,20,0.82);backdrop-filter:blur(4px);">
    <div class="glass-card rounded-xl p-6 max-w-xs w-full text-center animate-[bounce_0.5s_ease-out]"
         style="border-color:var(--vw-neon-pink);box-shadow:0 0 24px var(--vw-neon-pink),0 0 60px rgba(255,0,204,0.3),inset 0 0 20px rgba(0,0,0,0.5);">
        <div class="text-5xl mb-4">🌆</div>
        <h2 class="font-orbitron mb-2 neon-text-yellow"
            style="font-size:2.2rem;font-weight:900;letter-spacing:0.1em;">BINGO!</h2>
        <p class="mb-6" style="color:var(--vw-text-dim);letter-spacing:0.08em;font-size:0.85rem;">YOU COMPLETED A LINE!</p>

        <button
            @onclick="OnDismiss"
            class="btn-neon w-full py-3 px-6 rounded-lg">
            KEEP PLAYING
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
