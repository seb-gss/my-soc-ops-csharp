@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    style="@GetInlineStyle()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-xs"
              style="color:var(--vw-neon-pink);text-shadow:0 0 6px var(--vw-neon-pink);">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center border rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight";
        var freeSpaceClasses = Square.IsFreeSpace ? "font-orbitron font-bold" : "";
        return $"{baseClasses} {freeSpaceClasses}";
    }

    private string GetInlineStyle()
    {
        if (Square.IsFreeSpace)
            return "background:rgba(255,0,204,0.12);border-color:var(--vw-neon-pink);color:var(--vw-neon-pink);text-shadow:0 0 8px var(--vw-neon-pink);box-shadow:0 0 8px rgba(255,0,204,0.4),inset 0 0 8px rgba(255,0,204,0.08);font-family:'Orbitron',monospace;letter-spacing:0.05em;";

        if (IsWinning)
            return "background:var(--vw-winning-bg);border-color:var(--vw-neon-yellow);color:var(--vw-neon-yellow);text-shadow:0 0 6px var(--vw-neon-yellow);box-shadow:0 0 10px rgba(255,242,0,0.5),inset 0 0 10px rgba(255,242,0,0.08);";

        if (Square.IsMarked)
            return "background:var(--vw-marked-bg);border-color:var(--vw-neon-pink);color:#ffffff;box-shadow:0 0 10px rgba(255,0,204,0.45),inset 0 0 8px rgba(255,0,204,0.08);";

        return "background:var(--vw-square-bg);border-color:rgba(0,245,255,0.35);color:rgba(255,255,255,0.8);";
    }
}
