@using SocOps.Models

<div class="flex flex-col min-h-full" style="background:var(--vw-bg);">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 border-b"
            style="background:rgba(10,0,21,0.95);border-color:var(--vw-neon-cyan);box-shadow:0 0 12px rgba(0,245,255,0.2);">
        <button
            @onclick="OnReset"
            style="font-family:'Share Tech Mono',monospace;font-size:0.85rem;color:var(--vw-neon-cyan);padding:0.375rem 0.75rem;border:1px solid rgba(0,245,255,0.35);border-radius:0.25rem;transition:all 0.15s;">
            ← BACK
        </button>
        <h1 class="font-orbitron"
            style="font-size:1rem;letter-spacing:0.2em;color:var(--vw-neon-yellow);text-shadow:0 0 8px var(--vw-neon-yellow);">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-sm py-2 px-4"
       style="color:var(--vw-neon-cyan);text-shadow:0 0 6px rgba(0,245,255,0.5);letter-spacing:0.05em;">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="text-center py-2 font-semibold text-sm"
             style="background:rgba(255,242,0,0.1);color:var(--vw-neon-yellow);text-shadow:0 0 10px var(--vw-neon-yellow);border-top:1px solid var(--vw-neon-yellow);border-bottom:1px solid var(--vw-neon-yellow);letter-spacing:0.15em;font-family:'Orbitron',monospace;">
            ★ BINGO! YOU GOT A LINE! ★
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3"
         style="background:radial-gradient(ellipse at center, rgba(62,0,110,0.4) 0%, var(--vw-bg) 70%);">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
